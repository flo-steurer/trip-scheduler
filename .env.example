PORT=8000
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Optional 2026 World Cup automatic markets (Austria, Germany, and Cape Verde only).
# Create a free football-data.org token at https://www.football-data.org/client/register and keep it private.
FOOTBALL_DATA_API_KEY=
WORLD_CUP_SYNC_ENABLED=false
WORLD_CUP_SYNC_INTERVAL_SECONDS=1200
# Set these when opening the app to VPN users. Use the exact address they use.
# PUBLIC_BASE_URL=http://100.64.0.10:8000
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,100.64.0.10
# CSRF_TRUSTED_ORIGINS=https://trips.example.internal
# DJANGO_SECURE_SSL_REDIRECT=true
